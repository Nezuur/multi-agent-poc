FROM python:3.11-slim

WORKDIR /workspace

# Install git for version control operations
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Set up dummy git config for the agent commits
RUN git config --global user.email "agent@poc.local" && \
    git config --global user.name "AI Agent"

# Prevent dubious ownership errors when the agent runs git commands
RUN git config --global --add safe.directory /workspace

# Because the docker-compose context is ../, we reference the file directly
COPY requirements-orchestrator.txt .
RUN pip install --no-cache-dir -r requirements-orchestrator.txt flake8

EXPOSE 8501

# Run the orchestrator from the mapped volume
CMD ["streamlit", "run", "orchestrator.py", "--server.port=8501", "--server.address=0.0.0.0"]
